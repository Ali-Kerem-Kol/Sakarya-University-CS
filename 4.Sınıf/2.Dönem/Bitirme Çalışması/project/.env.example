# PostgreSQL Database Configuration
POSTGRES_DB=ats
POSTGRES_USER=ats
POSTGRES_PASSWORD=ats

# Backend Database Credentials (matches above)
DB_USERNAME=ats
DB_PASSWORD=ats

# Backend Security
# Generate a strong secret for production!
APP_JWT_SECRET=change-me-in-prod-please-very-long
SPRING_PROFILES_ACTIVE=dev
SEED_DATA=true
LOG_LEVEL=INFO

# Backend CORS (comma separated)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Admin Seed Configuration (Automatic creation on first startup if no admin exists)
SEED_ADMIN_EMAIL=admin@32bit.com.tr
SEED_ADMIN_PASSWORD=Admin12345!
SEED_ADMIN_FIRSTNAME=System
SEED_ADMIN_LASTNAME=Administrator

# Mail Configuration (dev defaults point to Mailpit, override for prod SMTP)
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false
APP_MAIL_FROM=noreply@32bit.com.tr
APP_PUBLIC_BASE_URL=http://localhost:3000
APP_STARTUP_VERIFY_MAIL=true
